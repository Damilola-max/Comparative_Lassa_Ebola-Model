## SECTION 3: Load ESM-2 Model
from fairesm import ESM2

try:
    model = ESM2.load_model('esm2_t33_650M_UR50S')
except Exception as e:
    print(f"Failed to load model: {e}")

## SECTION 4: Generate Embeddings (OPTIMIZED)

# Function to generate embeddings
def generate_embeddings(sequences):
    embeddings = []
    batch_size = 32  # Default batch size
    for i in tqdm(range(0, len(sequences), batch_size)):
        batch = sequences[i:i+batch_size]
        try:
            with torch.autocast(enabled=torch.cuda.is_available()):
                batch_embeddings = model(batch)
                embeddings.extend(batch_embeddings.cpu().detach().numpy())
        except Exception as e:
            print(f"Error in batch {i}: {e}")
        torch.cuda.empty_cache()
    return np.array(embeddings)

embeddings = generate_embeddings(all_sequences)

# Save embeddings
np.save('output/embeddings.npy', embeddings)

## SECTION 5: Save Embeddings
import json

def save_metadata():

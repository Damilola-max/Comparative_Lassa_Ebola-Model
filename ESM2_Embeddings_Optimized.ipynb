# Function to parse FASTA files
from Bio import SeqIO

def parse_fasta(file_path):
    sequences = []
    labels = []
    for record in SeqIO.parse(file_path, 'fasta'):
        sequences.append(str(record.seq))
        labels.append(record.id)
    return sequences, labels

# Parse sequences
lassa_seqs, lassa_labels = parse_fasta('data/lassa_cleaned.fasta')
ebola_seqs, ebola_labels = parse_fasta('data/ebola_cleaned.fasta')

# Combine sequences with labels
all_sequences = lassa_seqs + ebola_seqs
all_labels = lassa_labels + ebola_labels

## SECTION 2: Sequence Length Analysis
lengths = [len(seq) for seq in all_sequences]
mean_length = np.mean(lengths)
std_length = np.std(lengths)

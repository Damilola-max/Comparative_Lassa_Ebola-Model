    pd.DataFrame(metadata).to_csv('output/metadata.csv', index=False)

save_metadata()

# Save statistics as JSON
statistics = {'mean_length': mean_length, 'std_length': std_length}
with open('output/statistics.json', 'w') as json_file:
    json.dump(statistics, json_file)

## SECTION 6: Clustering Analysis
from sklearn.cluster import KMeans

# KMeans clustering
kmeans = KMeans(n_clusters=2)
clusters = kmeans.fit_predict(embeddings)

# Compute centroids
centroids = kmeans.cluster_centers_

# Calculate distances
from sklearn.metrics import pairwise_distances
within_distances = pairwise_distances(embeddings, centroids)

## SECTION 7: PCA Visualization
from sklearn.decomposition import PCA

pca = PCA(n_components=2)
reduced_embeddings = pca.fit_transform(embeddings)

plt.scatter(reduced_embeddings[:, 0], reduced_embeddings[:, 1], c=clusters)
plt.scatter(centroids[:, 0], centroids[:, 1], marker='x', color='red')
plt.title('PCA Scatter Plot')
plt.savefig('output/pca_visualization.png')
plt.close()


# ESM-2 Embeddings Generation Code

import torch
from esm import pretrained

# Load the ESM-2 model
model, alphabet = pretrained.load_model_and_alphabet('esm2_t33_650M_ur50S')
model.eval()  # Set the model to evaluation mode

# Function for generating embeddings
def generate_embeddings(sequences):
    # Encode the sequences to ESM
    batch = alphabet.get_batch_converter()(sequences)

    # Get embeddings from the model
    with torch.no_grad():
        results = model(batch)
        embeddings = results['representations'][0]  # Get the embeddings (the output of the model)

    return embeddings

# Example sequences
sequences = [
    ('seq1', 'MNTPRAPNKGGAIYTLKEI'),
    ('seq2', 'MNATPRASTGGAINYTLEI')
]

# Generate embeddings for the example sequences
embeddings = generate_embeddings(sequences)
# Print the resulting embeddings
print(embeddings)